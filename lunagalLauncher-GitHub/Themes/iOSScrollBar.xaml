<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================================
    iOSScrollBar.xaml — 全局 iOS 风格滚动条资源覆盖
    ============================================================================

    目标 (Goal):
    消除 WinUI 3 默认 ScrollBar 在 NavigationView 展开/收回时右侧滚动条处
    产生的"弹出/收回"动画 (Thumb 宽度从 ScrollBarSize → ScrollBarExpandedSize 
    补间)，换成恒定宽度、颜色渐变的 iOS 风格平滑表现。

    做法 (Approach):
    WinUI 3 的 ScrollBar ControlTemplate 使用 `<Track>` 之类的 WPF-only 类型，
    不能在 WinUI 端重写。正确的干预点是覆盖它依赖的几项 *theme resources*:

      - ScrollBarSize / ScrollBarExpandedSize              ← 宽度/高度
      - ScrollBarThumbThickness / ScrollBarThumbExpandedThickness
      - ScrollBarExpandBeginTime / ScrollBarExpandDuration ← 展开动画时长
      - ScrollBarCollapseBeginTime / ScrollBarCollapseDuration ← 收起动画时长
      - ScrollBarFocusedOpacity / ScrollBarPointerOverOpacity ← 各阶段不透明度
      - ScrollBar*Fill* 颜色                                ← 指示器颜色

    让 Size == ExpandedSize 且 Expand/Collapse Duration == 0，
    再配合统一的 Fill 颜色，默认模板里所有 Storyboard 的 "从 A 补间到 B" 都会变成
    "从 A 瞬时跳到 A" —— 视觉上就是没有任何弹出/收回动画。

    颜色本身的过渡仍然是平滑的（WinUI 3 会对 Fill 属性做内部渐变），恰好实现了
    iOS 风格的纯透明度过渡。

    顺带把 ScrollBar*Fill 颜色提到一个柔和的中性灰色半透明，视觉上更接近 iOS。
    ============================================================================
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 尺寸：常态 / 展开态保持一致 —— 消除宽度补间动画 -->
    <x:Double x:Key="ScrollBarSize">8</x:Double>
    <x:Double x:Key="ScrollBarExpandedSize">8</x:Double>
    <x:Double x:Key="ScrollBarThumbThickness">6</x:Double>
    <x:Double x:Key="ScrollBarThumbExpandedThickness">6</x:Double>

    <!-- 按钮隐藏 (iOS 无上下箭头) -->
    <x:Double x:Key="ScrollBarButtonHeight">0</x:Double>
    <x:Double x:Key="ScrollBarButtonWidth">0</x:Double>

    <!-- 圆角：常态 / 展开态保持一致 -->
    <CornerRadius x:Key="ScrollBarThumbCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="ScrollBarThumbExpandedCornerRadius">4</CornerRadius>

    <!--
        ========================================================================
        关键：把所有"展开 / 收起"动画时长归零
        ========================================================================
        默认情况下 WinUI 3 ScrollBar 在 IndicatorMode 切换 (MouseIndicator ↔
        NoIndicator) 和 ConsciousStates (Expanded ↔ Collapsed) 时各有几百毫秒
        的 Storyboard。NavigationView 展开/收起过程中 Frame 宽度持续变化，会
        高频触发这些切换 —— 导致用户看到的"弹出 / 收回"动画。
        把 Duration 归零后，这些状态机仍然运行，但补间立即完成，视觉无动画。
    -->
    <Duration x:Key="ScrollBarExpandBeginTime">0:0:0</Duration>
    <Duration x:Key="ScrollBarExpandDuration">0:0:0</Duration>
    <Duration x:Key="ScrollBarCollapseBeginTime">0:0:0</Duration>
    <Duration x:Key="ScrollBarCollapseDuration">0:0:0</Duration>
    <Duration x:Key="ScrollBarOpacityChangeDuration">0:0:0</Duration>
    <Duration x:Key="ScrollBarFadeDelay">0:0:0</Duration>
    <Duration x:Key="ScrollBarFadeOutDelay">0:0:0</Duration>

    <!--
        ========================================================================
        颜色：Thumb / Track / Button 全部切到统一的 iOS 风格半透明灰
        ========================================================================
        PointerOver / Pressed 颜色略深，与常态形成轻微对比 —— 这部分的颜色
        过渡仍然存在 (由 Fill 属性的平滑插值自然完成)，就是我们想要的 iOS 味。
    -->
    <SolidColorBrush x:Key="ScrollBarThumbFill" Color="#40808080"/>
    <SolidColorBrush x:Key="ScrollBarThumbFillPointerOver" Color="#80808080"/>
    <SolidColorBrush x:Key="ScrollBarThumbFillPressed" Color="#A0808080"/>
    <SolidColorBrush x:Key="ScrollBarThumbFillDisabled" Color="#20808080"/>

    <!-- 轨道 / 按钮背景全透明 (iOS 风格不显示轨道) -->
    <SolidColorBrush x:Key="ScrollBarTrackFill" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarTrackFillPointerOver" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarTrackFillPressed" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarTrackFillDisabled" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackgroundPointerOver" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackgroundPressed" Color="Transparent"/>

    <SolidColorBrush x:Key="ScrollBarButtonBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarButtonBackgroundPointerOver" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarButtonBackgroundPressed" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarButtonBackgroundDisabled" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarButtonArrowForeground" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarButtonArrowForegroundPointerOver" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarButtonArrowForegroundPressed" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarButtonArrowForegroundDisabled" Color="Transparent"/>

</ResourceDictionary>
