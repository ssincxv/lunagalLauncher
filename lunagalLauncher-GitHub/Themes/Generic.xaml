<!--
    ============================================================================
    Generic.xaml - CustomDropdown 控件样式模板
    ============================================================================
    
    项目: lunagalLauncher
    技术栈: WinUI 3, XAML, Composition API
    
    功能概述:
    - 自定义下拉框控件的视觉样式和模板定义
    - 支持文本输入和下拉选择的组合控件（类似 ComboBox）
    - 集成了多种动画效果：展开/收起、按钮按压、阴影淡入淡出
    
    核心特性:
    1. 输入框内嵌下拉按钮设计
    2. 自定义 Popup 弹出层，支持 Composition API 动画
    3. ThemeShadow 阴影效果，提升视觉层次感
    4. 响应式视觉状态（Normal, PointerOver, Focused, Disabled）
    
    动画系统:
    - 下拉框展开/收起: InsetClip.BottomInset 动画（200ms 线性）
    - 按钮按压: CompositeTransform.TranslateY 动画（100ms/200ms）
    - 阴影淡入淡出: Composition Opacity 动画（150ms/200ms）
    
    重要说明:
    - 所有 x:Name 的模板部件必须与 CustomDropdown.cs 中的常量匹配
    - Translation="0,0,8" 用于 ThemeShadow 的 Z 轴偏移
    - Padding="0" 确保间距完全由内容控制
    
    最后更新: 2026-02-10
    ============================================================================
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:lunagalLauncher.Controls">

    <!--
        ========================================================================
        TextBox 自定义样式（用于 CustomDropdown 内部）
        ========================================================================
        
        功能：移除 TextBox 的聚焦下划线，避免出现黑线效果
    -->
    <Style x:Key="CustomDropdownTextBoxStyle" TargetType="TextBox">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="12,8,40,8"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <!-- 关键：移除聚焦时的下划线 -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <ScrollViewer x:Name="ContentElement"
                                      Padding="{TemplateBinding Padding}"
                                      Margin="0"
                                      AutomationProperties.AccessibilityView="Raw"
                                      HorizontalScrollMode="Auto"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollMode="Auto"
                                      VerticalScrollBarVisibility="Hidden"
                                      IsTabStop="False"
                                      ZoomMode="Disabled"/>
                        <TextBlock x:Name="PlaceholderTextContentPresenter"
                                   Text="{TemplateBinding PlaceholderText}"
                                   Foreground="{ThemeResource TextControlPlaceholderForeground}"
                                   Margin="{TemplateBinding Padding}"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ========================================================================
        CustomDropdown 控件默认样式
        ========================================================================
        
        定义控件的默认外观和行为模板
        使用 WinUI 3 主题资源确保与系统主题一致
    -->
    <Style TargetType="local:CustomDropdown">
        <!-- 背景色：使用系统文本控件背景主题 -->
        <Setter Property="Background" Value="{ThemeResource TextControlBackground}"/>
        
        <!-- 边框颜色：使用系统文本控件边框主题 -->
        <Setter Property="BorderBrush" Value="{ThemeResource TextControlBorderBrush}"/>
        
        <!-- 边框粗细：1px 标准边框 -->
        <Setter Property="BorderThickness" Value="1"/>
        
        <!-- 前景色（文字颜色）：使用系统文本控件前景主题 -->
        <Setter Property="Foreground" Value="{ThemeResource TextControlForeground}"/>
        
        <!-- 字体家族：使用系统内容控件字体 -->
        <Setter Property="FontFamily" Value="{ThemeResource ContentControlThemeFontFamily}"/>
        
        <!-- 字体大小：使用系统控件内容字体大小 -->
        <Setter Property="FontSize" Value="{ThemeResource ControlContentThemeFontSize}"/>
        
        <!-- 最小宽度：120px 确保控件不会太窄 -->
        <Setter Property="MinWidth" Value="120"/>
        
        <!-- 最小高度：32px 标准控件高度 -->
        <Setter Property="MinHeight" Value="32"/>
        
        <!-- 下拉框最大高度：300px 防止内容过多时超出屏幕 -->
        <Setter Property="MaxDropDownHeight" Value="300"/>
        
        <!-- 水平对齐：拉伸填充可用宽度 -->
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        
        <!-- 垂直对齐：顶部对齐 -->
        <Setter Property="VerticalAlignment" Value="Top"/>
        <!--
            ================================================================
            控件模板定义
            ================================================================
            
            定义控件的视觉结构和交互元素
            所有命名部件（x:Name）会在 CustomDropdown.cs 中引用
        -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:CustomDropdown">
                    <!-- 
                        根容器：Grid 布局
                        包含三个主要部分：输入框容器 + 阴影元素 + 下拉弹出层
                    -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!--
                            ====================================================
                            输入框容器 (BorderElement)
                            ====================================================
                            
                            功能：
                            - 包裹文本输入框和下拉按钮
                            - 提供边框、背景和阴影效果
                            - 作为阴影动画的目标元素
                            
                            关键属性：
                            - Translation="0,0,8": Z 轴偏移 8px，用于 ThemeShadow 渲染
                            - CornerRadius="4": 圆角 4px，现代化设计
                            - x:Name="BorderElement": 必须命名，用于 C# 代码获取 Visual
                            - Grid.Row="0": 放在第一行
                            
                            动画：
                            - 按钮按下时：阴影 Opacity 0→1 (150ms)
                            - 按钮松开时：阴影 Opacity 1→0 (200ms)
                        -->
                        <Border x:Name="BorderElement"
                                Grid.Row="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            
                            <!-- 
                                内部 Grid：放置文本框和按钮
                                两个元素重叠布局，按钮在右侧
                            -->
                            <Grid>
                                <!--
                                    ============================================
                                    文本输入框 (PART_TextBox)
                                    ============================================
                                    
                                    功能：
                                    - 允许用户输入文本
                                    - 显示占位符提示
                                    - 支持文本绑定
                                    
                                    关键属性：
                                    - Style="{StaticResource CustomDropdownTextBoxStyle}": 使用自定义样式，移除聚焦下划线
                                    - x:Name="PART_TextBox": 模板部件名称，C# 代码中引用
                                -->
                                <TextBox x:Name="PART_TextBox"
                                         Style="{StaticResource CustomDropdownTextBoxStyle}"
                                         Text="{TemplateBinding Text}"
                                         PlaceholderText="{TemplateBinding PlaceholderText}"
                                         Foreground="{TemplateBinding Foreground}"
                                         FontFamily="{TemplateBinding FontFamily}"
                                         FontSize="{TemplateBinding FontSize}"/>

                                <!--
                                    ============================================
                                    下拉按钮 (PART_DropDownButton)
                                    ============================================
                                    
                                    功能：
                                    - 触发下拉框展开/收起
                                    - 显示下拉箭头图标
                                    - 支持按压动画
                                    
                                    关键属性：
                                    - Width/Height="32": 固定尺寸，确保点击区域
                                    - HorizontalAlignment="Right": 右对齐
                                    - Background="Transparent": 透明背景，融入输入框
                                    - BorderThickness="0": 无边框，扁平化设计
                                    - x:Name="PART_DropDownButton": 模板部件名称
                                    
                                    事件处理：
                                    - PointerPressed: 触发按压动画（图标下移 + 阴影淡入）
                                    - PointerReleased: 触发释放动画（图标弹跳 + 阴影淡出）
                                    - Click: 切换下拉框状态
                                -->
                                <Button x:Name="PART_DropDownButton"
                                        Width="32"
                                        Height="32"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter Background="Transparent"
                                                              BorderThickness="0"
                                                              Content="{TemplateBinding Content}"
                                                              HorizontalContentAlignment="Center"
                                                              VerticalContentAlignment="Center"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <FontIcon x:Name="PART_DropDownIcon"
                                              Glyph="&#xE70D;" 
                                              FontSize="12"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!--
                            ====================================================
                            阴影元素 (ShadowBorder)
                            ====================================================
                            
                            功能：
                            - 显示在输入框下方的阴影效果
                            - 通过 Composition API 动画化
                            
                            关键属性：
                            - Grid.Row="1": 放在第二行（输入框下方）
                            - Height="4": 高度 4px（更小更精致）
                            - Margin="4,0,4,0": 左右各缩进 4px，与输入框圆角对齐
                            - Opacity="0": 初始透明（无阴影）
                            - Background="#03000000": 1% 透明度的黑色（极其极其柔和）
                            - CornerRadius="0,0,4,4": 底部圆角 4px，与输入框圆角平滑过渡
                            - x:Name="ShadowBorder": 用于 C# 代码引用
                        -->
                        <Border x:Name="ShadowBorder"
                                Grid.Row="1"
                                Height="4"
                                Margin="4,0,4,0"
                                Opacity="0"
                                Background="#03000000"
                                CornerRadius="0,0,4,4"/>


                        <!--
                            ====================================================
                            下拉弹出层 (PART_Popup)
                            ====================================================
                            
                            功能：
                            - 显示下拉选项内容
                            - 支持展开/收起动画
                            - 浮动在输入框上方（Z 轴）
                            
                            关键属性：
                            - IsOpen="False": 默认关闭状态
                            - IsLightDismissEnabled="False": 禁用点击外部关闭
                              （由 C# 代码手动控制关闭逻辑）
                            - VerticalOffset="42": 向下偏移 42px
                              （输入框高度 32px + 间距 10px）
                            - x:Name="PART_Popup": 模板部件名称
                            
                            设计决策：
                            - 不使用 LightDismiss，避免与自定义关闭逻辑冲突
                            - VerticalOffset 确保下拉框紧贴输入框下方
                        -->
                        <Popup x:Name="PART_Popup"
                               IsOpen="False"
                               IsLightDismissEnabled="False"
                               VerticalOffset="42">
                            <!--
                                ============================================
                                弹出层边框容器 (PART_PopupBorder)
                                ============================================
                                
                                功能：
                                - 提供下拉框的背景、边框容器
                                - 阴影通过 C# 代码中的 SpriteVisual + DropShadow 实现
                                
                                关键属性：
                                - Padding="0": 间距由内容自行控制
                                - MinWidth="300": 最小宽度 300px
                                - MinHeight="0": 允许高度为 0（动画起始状态）
                                - CornerRadius="4": 圆角与输入框一致
                                - x:Name="PART_PopupBorder": 模板部件名称
                                
                                背景和边框：
                                - Background: 使用系统层填充颜色（半透明）
                                - BorderBrush: 使用系统卡片描边颜色
                                - 注意：不再使用 ThemeShadow，改用 C# 中的 DropShadow
                                
                                设计决策：
                                - Padding="0" 是关键！避免间距不一致
                                - MinHeight="0" 允许动画从 0 开始
                                - 移除了 Translation 和 Shadow 属性，由 C# 代码控制
                            -->
                            <Grid x:Name="PART_PopupGrid">
                                <!-- 内容层：使用 InsetClip 动画 -->
                                <Border x:Name="PART_PopupBorder"
                                        Background="{ThemeResource SolidBackgroundFillColorBase}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="0"
                                        MinHeight="0">
                                    <!--
                                        ========================================
                                        内容呈现器 (PART_ContentPresenter)
                                        ========================================
                                        
                                        功能：
                                        - 显示用户自定义的下拉内容
                                        - 通过 C# 代码中的 InsetClip 裁剪
                                        
                                        关键属性：
                                        - Content="{TemplateBinding Content}": 绑定控件内容
                                        - Margin="0": 无额外边距
                                        - x:Name="PART_ContentPresenter": 模板部件名称
                                        
                                        动画：
                                        - 展开：InsetClip.BottomInset 从 targetHeight→0 (200ms)
                                        - 收起：InsetClip.BottomInset 从 0→currentHeight (200ms)
                                        - 使用 LinearEasingFunction（线性匀速）
                                        
                                        技术细节：
                                        - C# 代码通过 ElementCompositionPreview.GetElementVisual()
                                          获取 PopupBorder 的 Visual
                                        - 使用 Composition API 的 InsetClip 实现裁剪动画
                                        - BottomInset 控制底部裁剪量，实现高度增量效果
                                    -->
                                    <ContentPresenter x:Name="PART_ContentPresenter"
                                                      Content="{TemplateBinding Content}"
                                                      Margin="0"/>
                                </Border>
                                
                                <!-- 阴影层：使用 ScaleY 动画，放在内容层后面 -->
                                <Border x:Name="PART_ShadowBorder"
                                        Background="Transparent"
                                        CornerRadius="4"
                                        RenderTransformOrigin="0.5,0"
                                        IsHitTestVisible="False">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="PART_ShadowScale" ScaleY="0" />
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Popup>


                        <!--
                            ====================================================
                            视觉状态管理器 (VisualStateManager)
                            ====================================================
                            
                            功能：
                            - 定义控件在不同交互状态下的视觉变化
                            - 自动响应用户交互（鼠标悬停、聚焦、禁用）
                            - 使用 WinUI 3 主题资源确保一致性
                            
                            状态组：CommonStates
                            - Normal: 正常状态（默认）
                            - PointerOver: 鼠标悬停状态
                            - Focused: 获得焦点状态
                            - Disabled: 禁用状态
                            
                            技术说明：
                            - VisualStateManager 由 WinUI 框架自动管理
                            - 状态切换时会自动应用对应的 Setter
                            - 使用 ThemeResource 确保明暗主题切换时自动更新
                        -->
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <!--
                                    ========================================
                                    Normal 状态（正常状态）
                                    ========================================
                                    
                                    触发条件：
                                    - 控件未被鼠标悬停
                                    - 控件未获得焦点
                                    - 控件未被禁用
                                    
                                    视觉效果：
                                    - 使用默认的 Setter 属性值
                                    - 无需额外设置
                                -->
                                <VisualState x:Name="Normal"/>
                                
                                <!--
                                    ========================================
                                    PointerOver 状态（鼠标悬停）
                                    ========================================
                                    
                                    触发条件：
                                    - 鼠标指针移动到控件上方
                                    
                                    视觉效果：
                                    - 边框颜色变化：使用悬停主题色
                                    - 背景颜色变化：使用悬停背景色
                                    - 提供视觉反馈，提示用户可交互
                                -->
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <!-- 边框颜色：悬停时的边框主题色 -->
                                        <Setter Target="BorderElement.BorderBrush" Value="{ThemeResource TextControlBorderBrushPointerOver}"/>
                                        <!-- 背景颜色：悬停时的背景主题色 -->
                                        <Setter Target="BorderElement.Background" Value="{ThemeResource TextControlBackgroundPointerOver}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                
                                <!--
                                    ========================================
                                    Focused 状态（获得焦点）
                                    ========================================
                                    
                                    触发条件：
                                    - 用户点击控件
                                    - 用户通过 Tab 键导航到控件
                                    
                                    视觉效果：
                                    - 边框颜色变化：使用聚焦主题色（通常是强调色）
                                    - 背景颜色变化：使用聚焦背景色
                                    - 边框保持 1px（不加粗，避免黑线效果）
                                    - 提供明确的焦点指示，符合无障碍设计
                                -->
                                <VisualState x:Name="Focused">
                                    <VisualState.Setters>
                                        <!-- 边框颜色：聚焦时的边框主题色（强调色） -->
                                        <Setter Target="BorderElement.BorderBrush" Value="{ThemeResource TextControlBorderBrushFocused}"/>
                                        <!-- 背景颜色：聚焦时的背景主题色 -->
                                        <Setter Target="BorderElement.Background" Value="{ThemeResource TextControlBackgroundFocused}"/>
                                        <!-- 边框保持 1px：不加粗，避免出现明显的黑线 -->
                                        <Setter Target="BorderElement.BorderThickness" Value="1"/>
                                    </VisualState.Setters>
                                </VisualState>
                                
                                <!--
                                    ========================================
                                    Disabled 状态（禁用状态）
                                    ========================================
                                    
                                    触发条件：
                                    - IsEnabled 属性设置为 False
                                    
                                    视觉效果：
                                    - 边框颜色变灰：使用禁用边框主题色
                                    - 背景颜色变灰：使用禁用背景主题色
                                    - 文字颜色变灰：使用禁用前景主题色
                                    - 提示用户控件不可交互
                                -->
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <!-- 边框颜色：禁用时的边框主题色（灰色） -->
                                        <Setter Target="BorderElement.BorderBrush" Value="{ThemeResource TextControlBorderBrushDisabled}"/>
                                        <!-- 背景颜色：禁用时的背景主题色（灰色） -->
                                        <Setter Target="BorderElement.Background" Value="{ThemeResource TextControlBackgroundDisabled}"/>
                                        <!-- 文字颜色：禁用时的前景主题色（浅灰色） -->
                                        <Setter Target="PART_TextBox.Foreground" Value="{ThemeResource TextControlForegroundDisabled}"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
