<?xml version="1.0" encoding="utf-8"?>
<!--
    LlamaServicePage.xaml
    
    Purpose: 提供 llama-server 服务的完整管理界面
    
    功能概述:
    - 服务生命周期管理（启动、停止、重启）
    - 服务状态实时监控
    - 模型文件选择和路径配置
    - GPU 硬件配置和优化
    - 网络参数配置（主机、端口）
    - 性能参数调优（上下文长度、并行线程）
    - 配置预设的保存和加载
    - 自定义命令行参数支持
    
    依赖项:
    - lunagalLauncher.Behaviors: 提供 UI 动画行为
    - Code-behind: LlamaServicePage.xaml.cs 处理业务逻辑
-->
<Page
    x:Class="lunagalLauncher.Views.LlamaServicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:lunagalLauncher.Behaviors"
    xmlns:controls="using:lunagalLauncher.Controls"
    mc:Ignorable="d">
    
    <!-- 页面资源 -->
    <Page.Resources>
        <!--
            ScrollBar 相关资源已统一迁至 /Themes/iOSScrollBar.xaml (由 App.xaml 合并)，
            让所有页面共用一套 iOS 风格外观，消除导航栏展开/收起时的"弹出/收回"动画。
            ScrollBar resources moved to /Themes/iOSScrollBar.xaml (merged by App.xaml)
            so every page shares one iOS-style look with no pane-toggle pop animation.
        -->

        <!-- 端口按钮样式 - 无视觉反馈 -->
        <Style x:Key="PortButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter x:Name="ContentPresenter"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Content="{TemplateBinding Content}"
                                        ContentTransitions="{TemplateBinding ContentTransitions}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        Padding="{TemplateBinding Padding}"
                                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                        AutomationProperties.AccessibilityView="Raw"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <!-- 页面背景：浅灰色 (#FAFAFA) 提供柔和的视觉体验 -->
    <Page.Background>
        <SolidColorBrush Color="#FAFAFA"/>
    </Page.Background>

    <!-- 
        ScrollViewer: 允许页面内容垂直滚动
        - VerticalScrollBarVisibility="Auto": 内容超出时自动显示滚动条
    -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" Tapped="Page_Tapped">
        <!-- 
            主容器 StackPanel
            - Padding="24,24,40,24": 左上右下内边距，右侧额外空间避免滚动条遮挡
            - Spacing="16": 子元素之间的垂直间距
        -->
        <!--
            注意 (NOTE):
            早期版本这里挂了 <RepositionThemeTransition> —— 该 Fluent 过渡会在子元素
            每次重排 / 位置变化时播放 "滑入/滑回" 动画。在 NavigationView 展开/收起
            导航栏时，内容区 Width 会按帧变化 (~10-15 帧 / 167ms)，每一帧都触发一次
            reposition 滑动，于是用户在右侧 (ScrollBar / 控件列表那条边) 看到
            "弹出/收回" 的突兀动画。移除该过渡后，子元素只跟随容器 layout 自然移动
            —— 这正是 iOS 风格的平滑过渡应该呈现的效果。
            Removed RepositionThemeTransition: it replayed a slide animation
            per-frame during NavigationView pane toggle, causing the visible
            "pop/retract" the user reported on the right side. Natural layout
            reflow (no overlaid slide tweens) is what iOS-style smoothness
            actually looks like.
        -->
        <StackPanel Padding="24,24,40,24" Spacing="16">
            
            <!-- 
                ═══════════════════════════════════════════════════════════
                区域 1: 页面标题
                ═══════════════════════════════════════════════════════════
            -->
            <StackPanel Spacing="8">
                <!-- 主标题：使用系统预定义的标题样式 -->
                <TextBlock Text="llama 服务管理" Style="{StaticResource TitleTextBlockStyle}"/>
            </StackPanel>

            <!-- 
                ═══════════════════════════════════════════════════════════
                区域 2: 服务状态卡片
                ═══════════════════════════════════════════════════════════
                实时显示 llama-server 服务的运行状态
                - 使用圆形指示器（Ellipse）显示状态颜色
                - 文本描述当前状态（未启动/运行中/已停止等）
            -->
            <Border x:Name="ParamsInfoBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Shadow="{x:Null}">
                <StackPanel Spacing="12">
                    <!-- 卡片标题 -->
                    <TextBlock Text="服务状态" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    
                    <!-- 状态指示器和文本 -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <!-- 
                            状态指示器圆点
                            - 灰色: 未启动
                            - 绿色: 运行中
                            - 红色: 已停止/错误
                            - 黄色: 启动中/过渡状态
                            由 Code-behind 动态更新颜色
                        -->
                        <Ellipse x:Name="StatusIndicator" Width="16" Height="16" Fill="Gray"/>
                        
                        <!-- 状态文本描述，由 Code-behind 动态更新 -->
                        <TextBlock x:Name="StatusText" Text="未启动" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 
                ═══════════════════════════════════════════════════════════
                区域 2.5: 参数信息显示区域
                ═══════════════════════════════════════════════════════════
                显示 llama 服务的参数信息（如 prompt eval time, eval time, total time 等）
                - 使用 TextBox 以获得更好的文本选择性能
                - 只读模式，支持 Ctrl+C 复制
            -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Shadow="{x:Null}">
                <StackPanel Spacing="12">
                    <TextBlock Text="参数信息" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Height="200">
                        <TextBox x:Name="ParamsOutputBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="8"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 Shadow="{x:Null}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <ScrollViewer x:Name="ContentElement"
                                                                  Padding="{TemplateBinding Padding}"
                                                                  Margin="0"
                                                                  AutomationProperties.AccessibilityView="Raw"
                                                                  HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                                                  HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                                  VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                                                  VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                                                  IsTabStop="False"
                                                                  ZoomMode="Disabled"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 
                ═══════════════════════════════════════════════════════════
                区域 3: 服务控制按钮组
                ═══════════════════════════════════════════════════════════
                提供服务生命周期管理的核心操作按钮
                - 启动服务: 使用 Accent 样式突出显示主要操作
                - 停止服务: 初始禁用，服务运行时启用
                - 重启服务: 初始禁用，服务运行时启用
                按钮状态由 Code-behind 根据服务状态动态管理
            -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <!-- 
                    启动按钮
                    - AccentButtonStyle: 使用强调色，表示这是主要操作
                    - Click 事件: StartButton_Click 处理服务启动逻辑
                -->
                <Button x:Name="StartButton" Content="启动服务" Click="StartButton_Click" Style="{StaticResource AccentButtonStyle}"/>
                
                <!-- 
                    停止按钮
                    - IsEnabled="False": 默认禁用，只有服务运行时才启用
                    - Click 事件: StopButton_Click 处理服务停止逻辑
                -->
                <Button x:Name="StopButton" Content="停止服务" Click="StopButton_Click" IsEnabled="False"/>
                
                <!-- 
                    重启按钮
                    - IsEnabled="False": 默认禁用，只有服务运行时才启用
                    - Click 事件: RestartButton_Click 处理服务重启逻辑（先停止再启动）
                -->
                <Button x:Name="RestartButton" Content="重启服务" Click="RestartButton_Click" IsEnabled="False"/>
            </StackPanel>

            <!-- 
                ═══════════════════════════════════════════════════════════
                区域 4: llama-server 路径配置
                ═══════════════════════════════════════════════════════════
                允许用户选择 llama-server.exe 的文件路径
                - 支持手动输入路径
                - 支持通过文件浏览器选择
            -->
            <StackPanel Spacing="8">
                <!-- 配置项标题 -->
                <TextBlock Text="llama-server" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                
                <!-- 路径输入和浏览按钮的网格布局 -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <!-- 第一列：自适应宽度，用于路径输入框 -->
                        <ColumnDefinition Width="*"/>
                        <!-- 第二列：自动宽度，用于浏览按钮 -->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 
                        路径输入框
                        - PlaceholderText: 提示用户输入内容
                        - Grid.Column="0": 放置在第一列
                    -->
                    <!--
                        与端口输入一致：圆角 Border + 透明 TextBox + 底部阴影（无下拉、无上下箭头）
                        TextChanged 同步 config.ServicePath（含直接输入/粘贴）。
                    -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="ServicePathBorderElement"
                                Grid.Row="0"
                                Background="{ThemeResource TextControlBackground}"
                                BorderBrush="{ThemeResource TextControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBox x:Name="ServicePathTextBox"
                                     PlaceholderText="选择 llama-server.exe 文件路径"
                                     TextChanged="ServicePathTextBox_TextChanged"
                                     HorizontalAlignment="Stretch"
                                     MinHeight="32"
                                     Padding="12,8,12,8"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalAlignment="Center"
                                     IsTextPredictionEnabled="False"
                                     UseSystemFocusVisuals="False">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Grid>
                                            <Grid.Resources>
                                                <Style x:Name="DeleteButtonStyleServicePath" TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="ButtonLayoutGrid" Visibility="Collapsed"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Grid.Resources>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <ContentPresenter x:Name="HeaderContentPresenter"
                                                              Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                                              Content="{TemplateBinding Header}"
                                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                              FontWeight="Normal"
                                                              Foreground="{ThemeResource TextControlHeaderForeground}"
                                                              Margin="{ThemeResource TextBoxTopHeaderMargin}"
                                                              TextWrapping="Wrap"
                                                              VerticalAlignment="Top"
                                                              Visibility="Collapsed"
                                                              x:DeferLoadStrategy="Lazy"/>
                                            <Border x:Name="BorderElement"
                                                    Grid.Row="1" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="2"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="{TemplateBinding CornerRadius}"
                                                    MinWidth="{ThemeResource TextControlThemeMinWidth}"
                                                    MinHeight="{ThemeResource TextControlThemeMinHeight}"/>
                                            <ScrollViewer x:Name="ContentElement"
                                                          Grid.Row="1" Grid.Column="0"
                                                          HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                          VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                                          IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}"
                                                          IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}"
                                                          IsTabStop="False"
                                                          Margin="{TemplateBinding BorderThickness}"
                                                          Padding="{TemplateBinding Padding}"
                                                          ZoomMode="Disabled"
                                                          AutomationProperties.AccessibilityView="Raw"/>
                                            <TextBlock x:Name="PlaceholderTextContentPresenter"
                                                       Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                       Foreground="{ThemeResource TextControlPlaceholderForeground}"
                                                       Margin="{TemplateBinding BorderThickness}"
                                                       Padding="{TemplateBinding Padding}"
                                                       Text="{TemplateBinding PlaceholderText}"
                                                       TextAlignment="{TemplateBinding TextAlignment}"
                                                       TextWrapping="{TemplateBinding TextWrapping}"
                                                       IsHitTestVisible="False"/>
                                        </Grid>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                        </Border>
                        <Border Grid.Row="1"
                                Height="4"
                                Margin="4,0,4,0"
                                Opacity="1"
                                Background="#08000000"
                                CornerRadius="0,0,4,4"/>
                    </Grid>
                    
                    <!-- 
                        浏览按钮
                        - Click 事件: BrowseServiceButton_Click 打开文件选择对话框
                        - Grid.Column="1": 放置在第二列
                    -->
                    <Button x:Name="BrowseServiceButton" 
                            Content="浏览..." 
                            Click="BrowseServiceButton_Click"
                            Grid.Column="1"
                            VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- 模型选择 -->
            <StackPanel Spacing="8">
                <TextBlock Text="GGUF模型" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- CustomDropdown 替代 Flyout -->
                    <controls:CustomDropdown x:Name="ModelPathComboBox" 
                                             Grid.Column="0"
                                             PlaceholderText="选择或输入模型文件路径"
                                             MaxDropDownHeight="450"
                                             HorizontalAlignment="Stretch">
                        <controls:CustomDropdown.Content>
                            <StackPanel MaxHeight="450">
                                <!-- 滚动列表 -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled"
                                              MaxHeight="360"
                                              Padding="24,16,24,16">
                                    <ItemsControl x:Name="ModelPathItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="ItemBorder"
                                                        Background="Transparent"
                                                        Margin="0,2"
                                                        CornerRadius="6"
                                                        Padding="16,0,4,0"
                                                        Tapped="ModelPathItem_Tapped"
                                                        DoubleTapped="ModelPathItem_DoubleTapped"
                                                        PointerPressed="ModelPathItem_PointerPressed"
                                                        PointerMoved="ModelPathItem_PointerMoved"
                                                        PointerReleased="ModelPathItem_PointerReleased"
                                                        PointerEntered="ItemBorder_PointerEntered"
                                                        PointerExited="ItemBorder_PointerExited">
                                                    <CheckBox Tag="{Binding}"
                                                              Padding="8,6"
                                                              IsHitTestVisible="False">
                                                        <TextBlock Text="{Binding}" 
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   LineHeight="20"/>
                                                    </CheckBox>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <!-- 分隔线 -->
                                <Border Height="1" 
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        Margin="16,6,16,6"/>
                                
                                <!-- 操作按钮栏 -->
                                <StackPanel Orientation="Horizontal" 
                                            Spacing="9" 
                                            Margin="24,7,24,13"
                                            HorizontalAlignment="Center">
                                    <Button Click="ModelPathSelectAll_Click"
                                            MinWidth="70"
                                            Height="30"
                                            CornerRadius="15"
                                            Padding="10,5"
                                            FontSize="11.5">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="✓" FontSize="11.5"/>
                                            <TextBlock Text="全选" FontSize="11.5"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="ModelPathClearAll_Click"
                                            MinWidth="70"
                                            Height="30"
                                            CornerRadius="15"
                                            Padding="10,5"
                                            FontSize="11.5">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="✗" FontSize="11.5"/>
                                            <TextBlock Text="清空" FontSize="11.5"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="ModelPathDelete_Click"
                                            MinWidth="70"
                                            Height="30"
                                            CornerRadius="15"
                                            Padding="10,5"
                                            FontSize="11.5">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="🗑" FontSize="11.5"/>
                                            <TextBlock Text="删除" FontSize="11.5"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </controls:CustomDropdown.Content>
                    </controls:CustomDropdown>
                    
                    <Button x:Name="BrowseModelButton" 
                            Content="浏览..." 
                            Click="BrowseModelButton_Click"
                            Grid.Column="1"/>
                </Grid>
            </StackPanel>

            <!-- 预设管理 -->
            <StackPanel Spacing="8">
                <TextBlock Text="配置预设" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- CustomDropdown 替代 Flyout -->
                    <controls:CustomDropdown x:Name="PresetComboBox" 
                                             Grid.Column="0"
                                             PlaceholderText="选择或输入预设名称"
                                             MaxDropDownHeight="450"
                                             HorizontalAlignment="Stretch">
                        <controls:CustomDropdown.Content>
                            <StackPanel MaxHeight="450" MinWidth="400">
                                <!-- 滚动列表 -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled"
                                              MaxHeight="360"
                                              Padding="24,16,24,16">
                                    <ItemsControl x:Name="PresetItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="ItemBorder"
                                                        Background="Transparent"
                                                        Margin="0,2"
                                                        CornerRadius="6"
                                                        Padding="16,0,4,0"
                                                        HorizontalAlignment="Stretch"
                                                        Tapped="PresetItem_Tapped"
                                                        DoubleTapped="PresetItem_DoubleTapped"
                                                        PointerPressed="PresetItem_PointerPressed"
                                                        PointerMoved="PresetItem_PointerMoved"
                                                        PointerReleased="PresetItem_PointerReleased"
                                                        PointerEntered="ItemBorder_PointerEntered"
                                                        PointerExited="ItemBorder_PointerExited">
                                                    <CheckBox Tag="{Binding}"
                                                              Padding="8,6"
                                                              HorizontalAlignment="Stretch"
                                                              IsHitTestVisible="False">
                                                        <TextBlock Text="{Binding}" 
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   LineHeight="20"/>
                                                    </CheckBox>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <!-- 分隔线 -->
                                <Border Height="1" 
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        Margin="16,6,16,6"/>
                                
                                <!-- 操作按钮栏 -->
                                <StackPanel Orientation="Horizontal" 
                                            Spacing="9" 
                                            Margin="24,7,24,13"
                                            HorizontalAlignment="Center">
                                    <Button Click="PresetSelectAll_Click"
                                            MinWidth="70"
                                            Height="30"
                                            CornerRadius="15"
                                            Padding="10,5"
                                            FontSize="11.5">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="✓" FontSize="11.5"/>
                                            <TextBlock Text="全选" FontSize="11.5"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="PresetClearAll_Click"
                                            MinWidth="70"
                                            Height="30"
                                            CornerRadius="15"
                                            Padding="10,5"
                                            FontSize="11.5">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="✗" FontSize="11.5"/>
                                            <TextBlock Text="清空" FontSize="11.5"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="PresetDelete_Click"
                                            MinWidth="70"
                                            Height="30"
                                            CornerRadius="15"
                                            Padding="10,5"
                                            FontSize="11.5">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="🗑" FontSize="11.5"/>
                                            <TextBlock Text="删除" FontSize="11.5"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </controls:CustomDropdown.Content>
                    </controls:CustomDropdown>
                    
                    <Button x:Name="SavePresetButton" 
                            Content="保存预设" 
                            Click="SavePresetButton_Click"
                            Grid.Column="1"/>
                </Grid>
            </StackPanel>

            <!-- 网络配置 -->
            <StackPanel Spacing="8">
                <TextBlock Text="网络配置" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 主机地址 -->
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="主机地址 (--host)"/>
                        <controls:CustomDropdown x:Name="HostComboBox" 
                                                 PlaceholderText="选择或输入主机地址"
                                                 Text="127.0.0.1"
                                                 MaxDropDownHeight="300"
                                                 HorizontalAlignment="Stretch">
                            <controls:CustomDropdown.Content>
                                <StackPanel MaxHeight="300" MinWidth="420">
                                    <!-- 滚动列表 -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  HorizontalScrollMode="Disabled"
                                                  MaxHeight="180"
                                                  Padding="24,16,24,16">
