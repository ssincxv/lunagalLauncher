<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="lunagalLauncher.Views.LogViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:lunagalLauncher.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    
    <Page.Background>
        <SolidColorBrush Color="#FAFAFA"/>
    </Page.Background>

    <!-- 日志页面布局 / Log page layout -->
    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <!-- 标题和工具栏 / Title and Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- 日志内容区域 / Log Content Area -->
            <RowDefinition Height="*"/>
            <!-- 底部操作栏 / Bottom Action Bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题和工具栏 / Title and Toolbar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 标题 / Title -->
            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="日志" FontSize="24" FontWeight="Bold"/>
            </StackPanel>

            <!-- 工具栏按钮 / Toolbar Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <!-- 刷新按钮 / Refresh Button -->
                <Button x:Name="RefreshButton"
                        Click="RefreshButton_Click"
                        ToolTipService.ToolTip="刷新；清空后仅追新日志，按住 Shift 刷新可从文件头重新加载全部">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="16"/>
                        <TextBlock Text="刷新"/>
                    </StackPanel>
                </Button>

                <!-- 清空按钮 / Clear Button -->
                <Button x:Name="ClearButton"
                        Click="ClearButton_Click"
                        ToolTipService.ToolTip="清空显示">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="16"/>
                        <TextBlock Text="清空"/>
                    </StackPanel>
                </Button>

                <!-- 打开日志文件夹按钮 / Open Log Folder Button -->
                <Button x:Name="OpenLogFolderButton"
                        Click="OpenLogFolderButton_Click"
                        ToolTipService.ToolTip="打开日志文件夹">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B7;" FontSize="16"/>
                        <TextBlock Text="打开文件夹"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 日志内容区域 / Log Content Area -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <!-- 加载中提示 / Loading Indicator -->
                <StackPanel x:Name="LoadingPanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <ProgressRing IsActive="True" Width="48" Height="48"/>
                    <TextBlock Text="正在加载日志..."
                               FontSize="16"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- 日志列表 / Log List (使用 ListView 支持虚拟化) -->
                <ListView x:Name="LogListView"
                          ItemsSource="{x:Bind LogItems, Mode=OneWay}"
                          SelectionMode="None"
                          Padding="12">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:LogItemViewModel">
                            <Border Padding="8,4"
                                    Margin="0,2"
                                    Background="{x:Bind BackgroundBrush, Mode=OneTime}"
                                    CornerRadius="4">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 时间戳 / Timestamp -->
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind Timestamp, Mode=OneTime}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>

                                    <!-- 日志级别 / Log Level -->
                                    <Border Grid.Column="1"
                                            Background="{x:Bind LevelBrush, Mode=OneTime}"
                                            CornerRadius="4"
                                            Padding="8,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Level, Mode=OneTime}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>

                                    <!-- 日志消息 / Log Message -->
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Message, Mode=OneTime}"
                                               FontFamily="Consolas"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <!-- 启用增量加载虚拟化 / Enable incremental loading virtualization -->
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>

                <!-- 空状态提示 / Empty State -->
                <StackPanel x:Name="EmptyStatePanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE8F4;"
                              FontSize="64"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="暂无日志记录"
                               FontSize="16"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Button Content="刷新日志" Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 底部操作栏 / Bottom Action Bar -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 日志统计信息 / Log Statistics -->
                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            Spacing="20"
                            VerticalAlignment="Center">
                    <!-- 总计 -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" 
                                  Glyph="&#xE8F4;" 
                                  FontSize="14"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="LogCountText"
                                   Text="总计: 0 条"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>

                    <!-- 分隔线 -->
                    <Border Width="1" 
                            Height="20"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                            VerticalAlignment="Center"/>

                    <!-- 错误 -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" 
                                  Glyph="&#xE783;" 
                                  FontSize="14"
                                  Foreground="#E74856"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="ErrorCountText"
                                   Text="错误: 0"
                                   VerticalAlignment="Center"
                                   Foreground="#E74856"/>
                    </StackPanel>

                    <!-- 警告 -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" 
                                  Glyph="&#xE7BA;" 
                                  FontSize="14"
                                  Foreground="#FFA500"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="WarningCountText"
                                   Text="警告: 0"
                                   VerticalAlignment="Center"
                                   Foreground="#FFA500"/>
                    </StackPanel>
                </StackPanel>

                <!-- 筛选级别 / Log Level Filter -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            Spacing="8"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="筛选级别"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ComboBox x:Name="LogLevelFilterComboBox"
                              SelectionChanged="LogLevelFilterComboBox_SelectionChanged"
                              MinWidth="100"
                              VerticalAlignment="Center"
                              SelectedIndex="0">
                        <ComboBoxItem Content="全部"/>
                        <ComboBoxItem Content="调试"/>
                        <ComboBoxItem Content="信息"/>
                        <ComboBoxItem Content="警告"/>
                        <ComboBoxItem Content="错误"/>
                        <ComboBoxItem Content="致命"/>
                    </ComboBox>
                </StackPanel>

                <!-- 自动滚动开关 / Auto Scroll Toggle
                     Toggled 事件在开关 OFF→ON 时立刻吸底一次，后续新日志会继续保持。
                     Toggling ON immediately snaps the view to the bottom so the
                     user sees the latest log without waiting for the next line. -->
                <ToggleSwitch Grid.Column="3"
                              x:Name="AutoScrollToggle"
                              OnContent="自动滚动"
                              OffContent="自动滚动"
                              IsOn="True"
                              VerticalAlignment="Center"
                              MinWidth="0"
                              Toggled="AutoScrollToggle_Toggled"/>
            </Grid>
        </Border>
    </Grid>
</Page>
