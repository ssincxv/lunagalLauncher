<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="lunagalLauncher.Views.MouseMappingRuleRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:lunagalLauncher.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- 与 LlamaServicePage 端口/上下文长度旁箭头按钮一致 -->
        <Style x:Key="PortButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter x:Name="ContentPresenter"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Content="{TemplateBinding Content}"
                                          ContentTransitions="{TemplateBinding ContentTransitions}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          AutomationProperties.AccessibilityView="Raw"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- 与 beifen24 卡片风格：主题卡片底与描边 -->
    <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
        <StackPanel Spacing="16">
            <!-- 名称与优先级（与 Llama 服务页端口输入：圆角 Border + 底阴影；优先级含箭头动画） -->
            <Grid ColumnSpacing="12" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="10">
                    <TextBlock Text="规则名称" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="NameBoxBorderElement" Grid.Row="0"
                                Tag="MouseMappingMsField"
                                Background="{ThemeResource TextControlBackground}"
                                BorderBrush="{ThemeResource TextControlBorderBrush}"
                                BorderThickness="1" CornerRadius="4">
                            <TextBox x:Name="NameBox" PlaceholderText="名称"
                                     HorizontalAlignment="Stretch" MinHeight="32"
                                     Padding="12,8,12,8" BorderThickness="0" Background="Transparent"
                                     VerticalAlignment="Center" IsTextPredictionEnabled="False"
                                     UseSystemFocusVisuals="False"
                                     TextChanged="NameBox_TextChanged">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Grid>
                                            <Grid.Resources>
                                                <Style x:Name="DeleteButtonStyleName" TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="ButtonLayoutGrid" Visibility="Collapsed"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Grid.Resources>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <ContentPresenter x:Name="HeaderContentPresenter" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                                              Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                              FontWeight="Normal" Foreground="{ThemeResource TextControlHeaderForeground}"
                                                              Margin="{ThemeResource TextBoxTopHeaderMargin}" TextWrapping="Wrap" VerticalAlignment="Top"
                                                              Visibility="Collapsed" x:DeferLoadStrategy="Lazy"/>
                                            <Border x:Name="BorderElement" Grid.Row="1" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="2"
                                                    Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{TemplateBinding CornerRadius}"
                                                    MinWidth="{ThemeResource TextControlThemeMinWidth}" MinHeight="{ThemeResource TextControlThemeMinHeight}"/>
                                            <ScrollViewer x:Name="ContentElement" Grid.Row="1" Grid.Column="0"
                                                          HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                          VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                                          IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}"
                                                          IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}"
                                                          IsTabStop="False" Margin="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                                                          ZoomMode="Disabled" AutomationProperties.AccessibilityView="Raw"/>
                                            <TextBlock x:Name="PlaceholderTextContentPresenter" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                       Foreground="{ThemeResource TextControlPlaceholderForeground}"
                                                       Margin="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                                                       Text="{TemplateBinding PlaceholderText}" TextAlignment="{TemplateBinding TextAlignment}"
                                                       TextWrapping="{TemplateBinding TextWrapping}" IsHitTestVisible="False"/>
                                        </Grid>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                        </Border>
                        <Border x:Name="NameBoxShadowBorder" Grid.Row="1" Height="4" Margin="4,0,4,0"
                                Opacity="0.45" Background="#08000000" CornerRadius="0,0,4,4"/>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="10">
                    <TextBlock Text="优先级" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="PriorityBorderElement" Grid.Row="0"
                                Tag="MouseMappingMsField"
                                Background="{ThemeResource TextControlBackground}"
                                BorderBrush="{ThemeResource TextControlBorderBrush}"
                                BorderThickness="1" CornerRadius="4">
                            <Grid>
                                <TextBox x:Name="PriorityTextBox" PlaceholderText="0"
                                         HorizontalAlignment="Stretch" MinHeight="32"
                                         Padding="12,8,40,8" BorderThickness="0" Background="Transparent"
                                         VerticalAlignment="Center" IsTextPredictionEnabled="False"
                                         UseSystemFocusVisuals="False"
                                         TextChanged="PriorityTextBox_TextChanged">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <Grid>
                                                <Grid.Resources>
                                                    <Style x:Name="DeleteButtonStylePriority" TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="ButtonLayoutGrid" Visibility="Collapsed"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Grid.Resources>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <ContentPresenter x:Name="HeaderContentPresenter" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                                                  Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                                  FontWeight="Normal" Foreground="{ThemeResource TextControlHeaderForeground}"
                                                                  Margin="{ThemeResource TextBoxTopHeaderMargin}" TextWrapping="Wrap" VerticalAlignment="Top"
                                                                  Visibility="Collapsed" x:DeferLoadStrategy="Lazy"/>
                                                <Border x:Name="BorderElement" Grid.Row="1" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="2"
                                                        Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{TemplateBinding CornerRadius}"
                                                        MinWidth="{ThemeResource TextControlThemeMinWidth}" MinHeight="{ThemeResource TextControlThemeMinHeight}"/>
                                                <ScrollViewer x:Name="ContentElement" Grid.Row="1" Grid.Column="0"
                                                              HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                                              HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                              VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                                              VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                                              IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}"
                                                              IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}"
                                                              IsTabStop="False" Margin="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                                                              ZoomMode="Disabled" AutomationProperties.AccessibilityView="Raw"/>
                                                <TextBlock x:Name="PlaceholderTextContentPresenter" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                           Foreground="{ThemeResource TextControlPlaceholderForeground}"
                                                           Margin="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                                                           Text="{TemplateBinding PlaceholderText}" TextAlignment="{TemplateBinding TextAlignment}"
                                                           TextWrapping="{TemplateBinding TextWrapping}" IsHitTestVisible="False"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="0" Margin="0,0,4,0" IsHitTestVisible="True">
                                    <Button x:Name="PriorityUpButton" Style="{StaticResource PortButtonStyle}"
                                            Click="PriorityUpButton_Click"
                                            Width="28" Height="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Button.RenderTransform>
                                            <CompositeTransform/>
                                        </Button.RenderTransform>
                                        <FontIcon Glyph="&#xE70E;" FontSize="10"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsHitTestVisible="False"/>
                                    </Button>
                                    <Button x:Name="PriorityDownButton" Style="{StaticResource PortButtonStyle}"
                                            Click="PriorityDownButton_Click"
                                            Width="28" Height="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Button.RenderTransform>
                                            <CompositeTransform/>
                                        </Button.RenderTransform>
                                        <FontIcon Glyph="&#xE70D;" FontSize="10"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsHitTestVisible="False"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border x:Name="PriorityShadowBorder" Grid.Row="1" Height="4" Margin="4,0,4,0"
                                Opacity="0.45" Background="#08000000" CornerRadius="0,0,4,4"/>
                    </Grid>
                </StackPanel>
                <ToggleSwitch x:Name="EnabledSwitch" Header="启用" OnContent="开" OffContent="关"
                              Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left"/>
            </Grid>

            <!-- 物理键：点击输入框后按鼠标键或键盘键录入（无下拉）；触发方式仍为 CustomDropdown -->
            <StackPanel Spacing="8">
                <TextBlock Text="物理键与触发" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="10">
                        <TextBlock Text="物理键" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Border x:Name="PhysicalKeyBorder"
                                Tag="PhysicalKeyCaptureHost"
                                Background="{ThemeResource TextControlBackground}"
                                BorderBrush="{ThemeResource TextControlBorderBrush}"
                                BorderThickness="1" CornerRadius="4" MinHeight="32"
                                PreviewKeyDown="PhysicalKeyBorder_PreviewKeyDown">
                            <TextBox x:Name="PhysicalKeyBox"
                                     Style="{StaticResource CustomDropdownTextBoxStyle}"
                                     PlaceholderText="先左键点此处聚焦，再按要绑定的鼠标或键盘键"
                                     IsReadOnly="False"
                                     Padding="12,8"
                                     BeforeTextChanging="PhysicalKeyBox_BeforeTextChanging"
                                     GotFocus="PhysicalKeyBox_GotFocus"
                                     LostFocus="PhysicalKeyBox_LostFocus"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="10">
                        <TextBlock Text="触发方式" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <controls:CustomDropdown x:Name="TriggerDropdown" PlaceholderText="选择触发" MaxDropDownHeight="260"
                                                 IsReadOnly="True"
                                                 HorizontalAlignment="Stretch">
                            <controls:CustomDropdown.Content>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240" Padding="16,12,16,12">
                                    <ItemsControl x:Name="TriggerDropdownItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="Transparent" Margin="0,2" CornerRadius="6" Padding="12,8"
                                                        Tapped="TriggerDropdownItem_Tapped"
                                                        PointerEntered="DropdownItemBorder_PointerEntered"
                                                        PointerExited="DropdownItemBorder_PointerExited">
                                                    <TextBlock Text="{Binding}" FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </controls:CustomDropdown.Content>
                        </controls:CustomDropdown>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- 行为模式：先于下方毫秒字段，先选 FireOnce/连发再调阈值与间隔 -->
            <StackPanel Spacing="10">
                <TextBlock Text="行为模式" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <controls:CustomDropdown x:Name="BehaviorDropdown" PlaceholderText="选择行为" MaxDropDownHeight="200"
                                         IsReadOnly="True"
                                         HorizontalAlignment="Stretch">
                    <controls:CustomDropdown.Content>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180" Padding="16,12,16,12">
                            <ItemsControl x:Name="BehaviorDropdownItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Margin="0,2" CornerRadius="6" Padding="12,8"
                                                Tapped="BehaviorDropdownItem_Tapped"
                                                PointerEntered="DropdownItemBorder_PointerEntered"
                                                PointerExited="DropdownItemBorder_PointerExited">
                                            <TextBlock Text="{Binding}" FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </controls:CustomDropdown.Content>
                </controls:CustomDropdown>
            </StackPanel>

            <!-- 双击/连击不展示阈值（引擎不用 HoldThreshold）；连发仅 RepeatWhileHeld；二者皆无则整行折叠 -->
            <Grid x:Name="MsTimingFieldsGrid" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HoldThresholdTimeColumn" Width="*"/>
                    <ColumnDefinition x:Name="RepeatIntervalTimeColumn" Width="0"/>
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="HoldThresholdFieldPanel" Grid.Column="0" Spacing="10">
                        <TextBlock x:Name="HoldThresholdCaptionTextBlock" Text="按住阈值 (ms)" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="HoldThresholdBorderElement" Grid.Row="0"
                                    Tag="MouseMappingMsField"
                                    Background="{ThemeResource TextControlBackground}"
                                    BorderBrush="{ThemeResource TextControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <TextBox x:Name="HoldThresholdTextBox"
                                             PlaceholderText="例如 200"
                                             HorizontalAlignment="Stretch" MinHeight="32"
                                             Padding="12,8,40,8" BorderThickness="0" Background="Transparent"
                                             VerticalAlignment="Center" IsTextPredictionEnabled="False"
                                             UseSystemFocusVisuals="False"
                                             TextChanged="HoldThresholdTextBox_TextChanged">
                                        <TextBox.Template>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <Grid.Resources>
                                                        <Style x:Name="DeleteButtonStyle" TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="ButtonLayoutGrid" Visibility="Collapsed"/>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Grid.Resources>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <ContentPresenter x:Name="HeaderContentPresenter" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                                                      Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                                      FontWeight="Normal" Foreground="{ThemeResource TextControlHeaderForeground}"
                                                                      Margin="{ThemeResource TextBoxTopHeaderMargin}" TextWrapping="Wrap" VerticalAlignment="Top"
                                                                      Visibility="Collapsed" x:DeferLoadStrategy="Lazy"/>
                                                    <Border x:Name="BorderElement" Grid.Row="1" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="2"
                                                            Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{TemplateBinding CornerRadius}"
                                                            MinWidth="{ThemeResource TextControlThemeMinWidth}" MinHeight="{ThemeResource TextControlThemeMinHeight}"/>
                                                    <ScrollViewer x:Name="ContentElement" Grid.Row="1" Grid.Column="0"
                                                                  HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                                                  HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                                  VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                                                  VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                                                  IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}"
                                                                  IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}"
                                                                  IsTabStop="False" Margin="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                                                                  ZoomMode="Disabled" AutomationProperties.AccessibilityView="Raw"/>
                                                    <TextBlock x:Name="PlaceholderTextContentPresenter" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                               Foreground="{ThemeResource TextControlPlaceholderForeground}"
                                                               Margin="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                                                               Text="{TemplateBinding PlaceholderText}" TextAlignment="{TemplateBinding TextAlignment}"
                                                               TextWrapping="{TemplateBinding TextWrapping}" IsHitTestVisible="False"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </TextBox.Template>
                                    </TextBox>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="0" Margin="0,0,4,0" IsHitTestVisible="True">
                                        <Button x:Name="HoldThresholdUpButton" Style="{StaticResource PortButtonStyle}"
                                                Click="HoldThresholdUpButton_Click"
                                                Width="28" Height="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Button.RenderTransform>
                                                <CompositeTransform/>
                                            </Button.RenderTransform>
                                            <FontIcon Glyph="&#xE70E;" FontSize="10"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsHitTestVisible="False"/>
                                        </Button>
                                        <Button x:Name="HoldThresholdDownButton" Style="{StaticResource PortButtonStyle}"
                                                Click="HoldThresholdDownButton_Click"
                                                Width="28" Height="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Button.RenderTransform>
                                                <CompositeTransform/>
                                            </Button.RenderTransform>
                                            <FontIcon Glyph="&#xE70D;" FontSize="10"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsHitTestVisible="False"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border x:Name="HoldThresholdShadowBorder" Grid.Row="1" Height="4" Margin="4,0,4,0"
                                    Opacity="0.45" Background="#08000000" CornerRadius="0,0,4,4"/>
                        </Grid>
                </StackPanel>
                <StackPanel x:Name="RepeatIntervalFieldPanel" Grid.Column="1" Spacing="10" Visibility="Collapsed">
                        <TextBlock Text="连发间隔 (ms)" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="RepeatIntervalBorderElement" Grid.Row="0"
                                    Tag="MouseMappingMsField"
                                    Background="{ThemeResource TextControlBackground}"
                                    BorderBrush="{ThemeResource TextControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <TextBox x:Name="RepeatIntervalTextBox"
                                             PlaceholderText="例如 100"
                                             HorizontalAlignment="Stretch" MinHeight="32"
                                             Padding="12,8,40,8" BorderThickness="0" Background="Transparent"
                                             VerticalAlignment="Center" IsTextPredictionEnabled="False"
                                             UseSystemFocusVisuals="False"
                                             TextChanged="RepeatIntervalTextBox_TextChanged">
                                        <TextBox.Template>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <Grid.Resources>
                                                        <Style x:Name="DeleteButtonStyleR" TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="ButtonLayoutGridR" Visibility="Collapsed"/>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Grid.Resources>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <ContentPresenter x:Name="HeaderContentPresenter" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                                                      Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                                      FontWeight="Normal" Foreground="{ThemeResource TextControlHeaderForeground}"
                                                                      Margin="{ThemeResource TextBoxTopHeaderMargin}" TextWrapping="Wrap" VerticalAlignment="Top"
                                                                      Visibility="Collapsed" x:DeferLoadStrategy="Lazy"/>
                                                    <Border x:Name="BorderElement" Grid.Row="1" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="2"
                                                            Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{TemplateBinding CornerRadius}"
                                                            MinWidth="{ThemeResource TextControlThemeMinWidth}" MinHeight="{ThemeResource TextControlThemeMinHeight}"/>
                                                    <ScrollViewer x:Name="ContentElement" Grid.Row="1" Grid.Column="0"
                                                                  HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                                                  HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                                  VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                                                  VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                                                  IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}"
                                                                  IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}"
                                                                  IsTabStop="False" Margin="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                                                                  ZoomMode="Disabled" AutomationProperties.AccessibilityView="Raw"/>
                                                    <TextBlock x:Name="PlaceholderTextContentPresenter" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                               Foreground="{ThemeResource TextControlPlaceholderForeground}"
                                                               Margin="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                                                               Text="{TemplateBinding PlaceholderText}" TextAlignment="{TemplateBinding TextAlignment}"
                                                               TextWrapping="{TemplateBinding TextWrapping}" IsHitTestVisible="False"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </TextBox.Template>
                                    </TextBox>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="0" Margin="0,0,4,0" IsHitTestVisible="True">
                                        <Button x:Name="RepeatIntervalUpButton" Style="{StaticResource PortButtonStyle}"
                                                Click="RepeatIntervalUpButton_Click"
                                                Width="28" Height="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Button.RenderTransform>
                                                <CompositeTransform/>
                                            </Button.RenderTransform>
                                            <FontIcon Glyph="&#xE70E;" FontSize="10"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsHitTestVisible="False"/>
                                        </Button>
                                        <Button x:Name="RepeatIntervalDownButton" Style="{StaticResource PortButtonStyle}"
                                                Click="RepeatIntervalDownButton_Click"
                                                Width="28" Height="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Button.RenderTransform>
                                                <CompositeTransform/>
                                            </Button.RenderTransform>
                                            <FontIcon Glyph="&#xE70D;" FontSize="10"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsHitTestVisible="False"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border x:Name="RepeatIntervalShadowBorder" Grid.Row="1" Height="4" Margin="4,0,4,0"
                                    Opacity="0.45" Background="#08000000" CornerRadius="0,0,4,4"/>
                        </Grid>
                </StackPanel>
            </Grid>

            <!-- 执行动作 -->
            <StackPanel Spacing="8">
                <TextBlock Text="执行动作" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="10">
                        <TextBlock Text="动作类型" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <controls:CustomDropdown x:Name="ActionDropdown" PlaceholderText="选择动作" MaxDropDownHeight="180"
                                                 IsReadOnly="True"
                                                 HorizontalAlignment="Stretch">
                            <controls:CustomDropdown.Content>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="160" Padding="16,12,16,12">
                                    <ItemsControl x:Name="ActionDropdownItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="Transparent" Margin="0,2" CornerRadius="6" Padding="12,8"
                                                        Tapped="ActionDropdownItem_Tapped"
                                                        PointerEntered="DropdownItemBorder_PointerEntered"
                                                        PointerExited="DropdownItemBorder_PointerExited">
                                                    <TextBlock Text="{Binding}" FontSize="13" LineHeight="20"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </controls:CustomDropdown.Content>
                        </controls:CustomDropdown>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="10">
                        <TextBlock x:Name="ActionSecondaryLabel" Text="模拟鼠标键" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <controls:CustomDropdown x:Name="SimMouseDropdown" PlaceholderText="选择模拟键" MaxDropDownHeight="260"
                                                 IsReadOnly="True"
                                                 HorizontalAlignment="Stretch">
                            <controls:CustomDropdown.Content>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240" Padding="16,12,16,12">
                                    <ItemsControl x:Name="SimMouseDropdownItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="Transparent" Margin="0,2" CornerRadius="6" Padding="12,8"
                                                        Tapped="SimMouseDropdownItem_Tapped"
                                                        PointerEntered="DropdownItemBorder_PointerEntered"
                                                        PointerExited="DropdownItemBorder_PointerExited">
                                                    <TextBlock Text="{Binding}" FontSize="13" LineHeight="20"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </controls:CustomDropdown.Content>
                        </controls:CustomDropdown>
                        <Border x:Name="KeyComboBorder" Visibility="Collapsed"
                                Tag="KeyComboCaptureHost"
                                Background="{ThemeResource TextControlBackground}"
                                BorderBrush="{ThemeResource TextControlBorderBrush}"
                                BorderThickness="1" CornerRadius="4" MinHeight="32"
                                PreviewKeyDown="KeyComboBorder_PreviewKeyDown">
                            <TextBox x:Name="KeyComboBox" Style="{StaticResource CustomDropdownTextBoxStyle}"
                                     PlaceholderText="点击后按下快捷键"
                                     IsReadOnly="True"
                                     Padding="12,8"
                                     GotFocus="KeyComboBox_GotFocus"
                                     LostFocus="KeyComboBox_LostFocus"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- 进程过滤（任务栏/边缘禁用已移至鼠标映射页「全局进程过滤」下方，对全部规则生效） -->
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <ToggleSwitch x:Name="RestrictToggle" Header="进程过滤" OnContent="开" OffContent="关" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel x:Name="ProcessFilterDetailsPanel" Spacing="8" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="过滤模式" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <controls:CustomDropdown x:Name="ContextModeDropdown" PlaceholderText="选择模式" MaxDropDownHeight="200"
                                             IsReadOnly="True"
                                             HorizontalAlignment="Stretch">
                        <controls:CustomDropdown.Content>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180" Padding="16,12,16,12">
                                <ItemsControl x:Name="ContextModeDropdownItems">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent" Margin="0,2" CornerRadius="6" Padding="12,8"
                                                    Tapped="ContextModeDropdownItem_Tapped"
                                                    PointerEntered="DropdownItemBorder_PointerEntered"
                                                    PointerExited="DropdownItemBorder_PointerExited">
                                                <TextBlock Text="{Binding}" FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </controls:CustomDropdown.Content>
                    </controls:CustomDropdown>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="过滤名单" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <Grid ColumnSpacing="8" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <controls:CustomDropdown x:Name="ProcessDropdown"
                                             PlaceholderText="在下拉中勾选或浏览添加；路径仅显示在过滤名单内"
                                             IsReadOnly="True"
                                             MaxDropDownHeight="420"
                                             HorizontalAlignment="Stretch">
                        <controls:CustomDropdown.Content>
                            <StackPanel MaxHeight="420">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              MaxHeight="320"
                                              Padding="24,16,24,8">
                                    <ItemsControl x:Name="ProcessItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="Transparent" Margin="0,2" CornerRadius="6" Padding="8,6"
                                                        Tapped="ProcessItemBorder_Tapped"
                                                        PointerEntered="ProcessItemBorder_PointerEntered"
                                                        PointerExited="ProcessItemBorder_PointerExited">
                                                    <CheckBox Padding="8,6" IsHitTestVisible="False" Tag="{Binding}">
                                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" LineHeight="20"/>
                                                    </CheckBox>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="16,6,16,6"/>
                                <StackPanel Orientation="Horizontal" Spacing="9" HorizontalAlignment="Center" Margin="24,0,24,12">
                                    <Button Click="ProcessSelectAll_Click" MinWidth="70" Height="30" CornerRadius="15" Padding="10,5" FontSize="11.5">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="✓" FontSize="11.5"/>
                                            <TextBlock Text="全选" FontSize="11.5"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="ProcessClearChecks_Click" MinWidth="70" Height="30" CornerRadius="15" Padding="10,5" FontSize="11.5">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="✗" FontSize="11.5"/>
                                            <TextBlock Text="清空" FontSize="11.5"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="ProcessDeleteSelected_Click" MinWidth="70" Height="30" CornerRadius="15" Padding="10,5" FontSize="11.5">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="🗑" FontSize="11.5"/>
                                            <TextBlock Text="删除" FontSize="11.5"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </controls:CustomDropdown.Content>
                    </controls:CustomDropdown>
                    <Button Grid.Column="1"
                            MinHeight="32"
                            Padding="10,0,12,0"
                            CornerRadius="4"
                            VerticalAlignment="Stretch"
                            Click="BrowseExe_Click"
                            ToolTipService.ToolTip="浏览并添加可执行文件">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;" FontSize="16"/>
                            <TextBlock Text="浏览…" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
                </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
