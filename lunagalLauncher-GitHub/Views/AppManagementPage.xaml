<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="lunagalLauncher.Views.AppManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:lunagalLauncher.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    
    <Page.Background>
        <SolidColorBrush Color="#FAFAFA"/>
    </Page.Background>

    <Page.Resources>
        <!--
            ScrollBar 相关资源已统一迁至 /Themes/iOSScrollBar.xaml (由 App.xaml 合并)。
            ScrollBar resources moved to /Themes/iOSScrollBar.xaml (merged by App.xaml).
        -->
        <!-- 主框架导航区将 ControlCornerRadius 设为 0；此处显式圆角 + 紧凑内边距，专用于「添加应用」 -->
        <Style x:Key="AppManagementAddAppButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <!-- 列表行内 32×32 图标按钮：统一圆角矩形，避免默认直角 -->
        <Style x:Key="AppManagementIconActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Page.Resources>

    <!-- 应用管理页面 / Application Management Page -->
    <!--
        注意 (NOTE):
        早期版本这里挂了 <RepositionThemeTransition> —— 该 Fluent 过渡会在子元素
        每次重排 / 位置变化时播放 "滑入/滑回" 动画。在 NavigationView 展开/收起
        导航栏时，内容区 Width 会按帧变化 (~10-15 帧 / 167ms)，每一帧都触发一次
        reposition 滑动，于是用户在右侧看到 "弹出/收回" 的突兀动画。
        为了得到 iOS 风格的平滑过渡 —— 让子元素只跟随容器 layout 自然移动、不再
        叠加滑动补间 —— 这里显式不装任何 Transition。
        Removed RepositionThemeTransition: it replays a slide animation per-frame
        during NavigationView pane toggle, producing the visible "pop/retract"
        the user reported. Natural layout reflow is what iOS-style smooth
        transitions actually look like.
    -->
    <Grid>
        <!-- 主内容区域 -->
        <Grid Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20" Spacing="8">
                <TextBlock Text="应用管理" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="管理启动应用列表，添加或删除应用程序"
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 应用列表 + 空状态：列表可滚动；空状态在同一格内水平/垂直居中叠加 -->
            <Grid Grid.Row="1">
                <ScrollViewer x:Name="AppListScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <!--
                        关键修复 (Root-cause fix for pane-toggle "pop/retract"):
                        ─────────────────────────────────────────────────────
                        ListView 默认挂了一组 ItemContainerTransitions:
                          - EntranceThemeTransition  (从边缘滑入)
                          - AddDeleteThemeTransition (项目增删时补间)
                          - ReorderThemeTransition   (重排时补间)
                          - ContentThemeTransition   (内容变更时补间)

                        NavigationView 切换 IsPaneOpen 时内容区 Width 按帧渐变；
                        ListView 虚拟化逻辑会把部分 item 短暂从 "realized → virtualized
                        → realized" 循环一遍 —— 每次 "re-realize" 都触发
                        EntranceThemeTransition，从右侧边缘"滑进来"。多个 item 叠加
                        之后，看上去就是整个右侧组件"弹出又收回"一次。

                        把 ItemContainerTransitions 显式置空 TransitionCollection ⇒
                        系统仍会走 add/remove/reorder 检测，但不再播放任何补间动画，
                        pane 展开 / 收起全程看到的就是 "内容随 pane 宽度自然平移"
                        —— 即所期望的平滑 iOS 风过渡。

                        Explicitly empty ItemContainerTransitions kills the
                        EntranceThemeTransition that re-fires whenever a row
                        gets re-realized due to viewport width change during
                        pane toggle. Without this collection cleared, WinUI
                        replays a slide-from-edge anim on every re-realize,
                        which compounds into the visible "pop/retract".
                    -->
                    <ListView x:Name="AppListView"
                              SelectionMode="None"
                              ItemsSource="{x:Bind AppItems, Mode=OneWay}"
                              ShowsScrollingPlaceholders="False"
                              Padding="0,0,0,24">
                        <ListView.ItemContainerTransitions>
                            <TransitionCollection/>
                        </ListView.ItemContainerTransitions>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:AppItemViewModel">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,8"
                                        MinHeight="80">
                                    <!--
                                        关键的布局重构 (Key layout restructuring):
                                        ─────────────────────────────────────────────────
                                        旧布局在 NavigationView 展开、整体宽度收窄时会
                                        *overflow* —— 图标 + 长应用名 + 4 个按钮的总宽度
                                        超过可用空间，右侧按钮就被挤出窗口 (用户看到的
                                        "弹出到窗口外 + 又回弹")。
                                        
                                        新布局 (flex):
                                          Col 0 (Auto) : 图标 48×48 —— 固定
                                          Col 1 (*)    : 名称 / 路径 / 状态 —— 弹性，不足
                                                        时文字用 CharacterEllipsis 省略，
                                                        保证永不撑破
                                          Col 2 (Auto) : 右侧操作按钮组 —— 固定
                                        
                                        这样无论导航栏多宽多窄，整行宽度 == 视口宽度，
                                        不再 overflow；pane toggle 过程中，名称/路径列
                                        的宽度按帧线性收缩或扩张，按钮组始终贴紧视口
                                        右边缘 —— 就是用户要的"组件整体按比例平移、永不
                                        溢出窗口"的效果。
                                        Old layout had fixed MinWidth + MaxWidth on inner
                                        text, forcing the row wider than the viewport
                                        during pane open. Replaced with a true flex grid
                                        whose middle column is the only variable one, so
                                        the row always == viewport width and buttons
                                        stay glued to the right edge at every animation
                                        frame.
                                    -->
                                    <!--
                                        紧凑布局 (compact layout):
                                        - ToggleSwitch 去掉 On/OffContent（"已启用/已禁用"在左侧
                                          StatusText 中已显示），只保留开关本体 ~44px；
                                        - 3 个图标按钮都显式设 32×32 + Padding=0，避免默认按钮内边距
                                          带来额外宽度；
                                        - Spacing 从 8 降到 6，极窄时节省 ~6px；
                                        - 中间弹性列 MinWidth=0，让 Col 1 在极窄时可以完全收缩为 0，
                                          避免 Col 2 被"挤出窗口"。
                                        
                                        改造后 Col 2 自然宽度 ≈ 44 + 6 + 32 + 6 + 32 + 6 + 32 = 158px
                                        (原 264px)，单行最小总宽 = 48 + 0 + 158 = 206px，
                                        配合外层 Border.Padding=16×2 + Page.Padding=24×2 = 80px，
                                        可在视口窄至 286px 时仍完整渲染所有按钮，不再溢出。
                                        
                                        Compact layout: drop ToggleSwitch's text (redundant with
                                        StatusText), pin buttons at 32x32, tighten spacing. Col 2
                                        shrinks from ~264px natural width to ~158px, so even at
                                        narrow viewports (window - pane - padding ≈ 286px) the
                                        whole row fits and no control gets pushed outside the
                                        window during pane toggle.
                                    -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*" MinWidth="0"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 左侧：应用图标 (固定 48×48) -->
                                        <Border Grid.Column="0"
                                                Width="48" Height="48"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Image Source="{x:Bind IconSource, Mode=OneWay}"
                                                       Stretch="Uniform"
                                                       Visibility="{x:Bind IconVisibility, Mode=OneWay}"/>
                                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                                          Glyph="&#xE8B7;"
                                                          FontSize="24"
                                                          Foreground="White"
                                                          Visibility="{x:Bind DefaultIconVisibility, Mode=OneWay}"/>
                                            </Grid>
                                        </Border>

                                        <!-- 中间：名称 / 路径 / 状态 (弹性，允许完全收缩) -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="16,0"
                                                    Spacing="4">
                                            <TextBlock Text="{x:Bind Name}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"/>
                                            <TextBlock Text="{x:Bind Path}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"/>
                                            <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{x:Bind StatusColor, Mode=OneWay}"/>
                                        </StackPanel>

                                        <!-- 右侧：紧凑操作按钮组 -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <!-- 去掉 OnContent/OffContent 让 ToggleSwitch 只剩开关本体；CornerRadius 与图标按钮统一圆角观感 -->
                                            <ToggleSwitch IsOn="{x:Bind Enabled, Mode=TwoWay}"
                                                          OnContent=""
                                                          OffContent=""
                                                          MinWidth="44"
                                                          CornerRadius="8"
                                                          VerticalAlignment="Center"/>

                                            <Button Click="LaunchAppButton_Click"
                                                    Tag="{x:Bind Id}"
                                                    Style="{StaticResource AppManagementIconActionButtonStyle}"
                                                    ToolTipService.ToolTip="启动应用">
                                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="16"/>
                                            </Button>

                                            <Button Click="EditAppButton_Click"
                                                    Tag="{x:Bind Id}"
                                                    Style="{StaticResource AppManagementIconActionButtonStyle}"
                                                    ToolTipService.ToolTip="编辑应用">
                                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;" FontSize="16"/>
                                            </Button>

                                            <Button Click="DeleteAppButton_Click"
                                                    Tag="{x:Bind Id}"
                                                    IsEnabled="{x:Bind CanDelete}"
                                                    Style="{StaticResource AppManagementIconActionButtonStyle}"
                                                    ToolTipService.ToolTip="删除应用">
                                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="16"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>

                <!-- 空状态提示（相对内容区整体居中，不再使用顶部 Margin 下推） -->
                <StackPanel x:Name="EmptyStatePanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <FontIcon FontFamily="Segoe MDL2 Assets"
                              Glyph="&#xE8B7;"
                              FontSize="64"
                              HorizontalAlignment="Center"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="还没有添加任何应用"
                               FontSize="18"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                    <Button Content="添加第一个应用"
                            Click="AddAppButton_Click"
                            HorizontalAlignment="Center"
                            Style="{StaticResource AppManagementAddAppButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- 固定在右上角的添加按钮 -->
        <Button x:Name="AddAppButton"
                Click="AddAppButton_Click"
                Style="{StaticResource AppManagementAddAppButtonStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="24">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="14"/>
                <TextBlock Text="添加应用" FontSize="13"/>
            </StackPanel>
        </Button>
    </Grid>
</Page>
