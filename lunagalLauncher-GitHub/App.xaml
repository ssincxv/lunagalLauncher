<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="lunagalLauncher.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:lunagalLauncher"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- 自定义控件样式 -->
                <ResourceDictionary Source="/Themes/Generic.xaml"/>
                <!-- 
                    全局 iOS 风格滚动条样式
                    覆盖 WinUI 3 默认 ScrollBar 的 "弹出/收回" 宽度动画为恒定宽度 + BrushTransition，
                    消除 NavigationView 展开/收起时右侧滚动条处出现的突变动画。
                    Must be merged AFTER XamlControlsResources so our implicit
                    Style TargetType="ScrollBar" wins over the default theme.
                -->
                <ResourceDictionary Source="/Themes/iOSScrollBar.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="#512BD4" />
            <SolidColorBrush x:Key="WhiteBrush" Color="White" />

            <x:Double x:Key="AppFontSize">14</x:Double>

            <Style x:Key="Action" TargetType="Button">
                <Setter Property="FontSize"
                        Value="{StaticResource AppFontSize}" />
                <Setter Property="Padding"
                        Value="14,10" />
            </Style>

            <Style x:Key="PrimaryAction"
                   TargetType="Button"
                   BasedOn="{StaticResource Action}">
                <Setter Property="Background"
                        Value="{StaticResource PrimaryBrush}" />
                <Setter Property="CornerRadius"
                        Value="8" />
                <Setter Property="Foreground"
                        Value="{StaticResource WhiteBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
